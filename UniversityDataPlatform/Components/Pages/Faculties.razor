@page "/faculties"
@using UniversityDataPlatform.Models
@using UniversityDataPlatform.Repositories.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject IFacultyRepository FacultyRepository
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Faculty Data Pools | KBU Data Platform</PageTitle>
 
<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1">Faculty Data Pools</h2>
            <p class="text-muted mb-0">Explore datasets organized by faculty.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="input-group search-box">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Search faculties..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <button class="btn btn-primary fw-bold px-3 border-0" @onclick="HandleNewContributionClick">
                <i class="bi bi-plus-circle me-1"></i> New Contribution
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(contributionErrorMessage))
    {
        <div class="alert alert-danger border-0 mb-4 text-center fw-bold" style="background-color: #fef2f2; color: #ef4444; border: 1px solid #fee2e2; border-radius: 8px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @contributionErrorMessage
        </div>
    }

    @if (faculties == null)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Loading data pools...</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var faculty in GetFilteredFaculties())
            {
                <div class="col faculty-col">
                    <a href="/faculty/@faculty.Id" class="text-decoration-none h-100 d-block">
                        <div class="card h-100 faculty-card-pro shadow-sm border-0 transition-all">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="icon-square bg-soft-primary text-primary rounded-3 me-3 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-building fs-3"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title text-dark fw-bold mb-0">@faculty.Name</h5>
                                        <span class="badge bg-light text-muted border x-small-text">KBU</span>
                                    </div>
                                </div>
                                
                                <p class="card-text text-muted small mb-4 text-truncate-2">
                                    This pool contains all raw and processed datasets shared by researchers within the @faculty.Name.
                                </p>

                                <div class="d-flex justify-content-between align-items-center text-muted small pt-3 border-top mt-auto">
                                    <span><i class="bi bi-database me-1"></i> 12 Datasets</span>
                                    <span class="text-primary fw-bold">View Pool <i class="bi bi-arrow-right ms-1"></i></span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

<style>
    :root {
        --kbu-blue: #4f46e5; /* KBÜ Koyu Mavi -> Indigo */
        --kbu-mavi-soft: #eef2ff;
    }

    .bg-soft-primary { background-color: var(--kbu-mavi-soft); }
    .text-primary { color: var(--kbu-blue) !important; }
    .btn-primary { background-color: var(--kbu-blue); border-color: var(--kbu-blue); }
    .btn-primary:hover { background-color: #4338ca; }

    .faculty-card-pro {
        border-radius: 12px;
        background-color: #fff;
        border: 1px solid #eaeaea !important;
    }

    .faculty-card-pro:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        border-color: rgba(79, 70, 229, 0.2) !important;
    }

    .icon-square { width: 60px; height: 60px; flex-shrink: 0; }
    
    .x-small-text { font-size: 0.75rem; padding: 3px 8px; }
    
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .search-box input { border-radius: 8px; min-width: 250px; }
    .transition-all { transition: all 0.3s ease-in-out; }
</style>

@code {
    private IEnumerable<Faculty>? faculties;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        faculties = await FacultyRepository.GetAllAsync();
    }

    private IEnumerable<Faculty> GetFilteredFaculties()
    {
        if (faculties == null) return new List<Faculty>();
        if (string.IsNullOrWhiteSpace(searchTerm)) return faculties;
        
        return faculties.Where(f => f.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
    }

    private string? contributionErrorMessage;

    private async Task HandleNewContributionClick()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity != null && user.Identity.IsAuthenticated && user.IsInRole("Admin"))
        {
            NavigationManager.NavigateTo("/upload-dataset");
        }
        else
        {
            contributionErrorMessage = "You do not have permission to contribute datasets. Please log in as an administrator.";
        }
    }
}