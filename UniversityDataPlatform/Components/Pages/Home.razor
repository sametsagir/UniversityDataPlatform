@code {
    private List<Dataset>? allDatasets;
    private string searchTerm = "";
    private string activeFilter = "all";
    private Dictionary<int, double> datasetBestScores = new();
    private HashSet<int> datasetIdsWithPapers = new();

    protected override async Task OnInitializedAsync()
    {
        // GEÇİCİ DÜZELTME: Veritabanında DatasetPapers tablosu zaten var olduğu için EF geçişini manuel işaretle
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            await context.Database.ExecuteSqlRawAsync(
                "IF NOT EXISTS (SELECT * FROM __EFMigrationsHistory WHERE MigrationId = '20260606135800_AddDatasetPapers') " +
                "INSERT INTO __EFMigrationsHistory (MigrationId, ProductVersion) VALUES ('20260606135800_AddDatasetPapers', '10.0.5')"
            );
        }
        catch { }

        // GEÇİCİ TEMİZLİK: Kırmızı Şarap Kalitesi Veri Setini Sil
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var dsToDelete = await context.Datasets.FirstOrDefaultAsync(d => d.Title.Contains("Şarap"));
            if (dsToDelete != null)
            {
                var papers = context.DatasetPapers.Where(p => p.DatasetId == dsToDelete.Id);
                context.DatasetPapers.RemoveRange(papers);

                var analyses = context.DatasetAnalyses.Where(a => a.DatasetId == dsToDelete.Id);
                context.DatasetAnalyses.RemoveRange(analyses);

                context.Datasets.Remove(dsToDelete);
                await context.SaveChangesAsync();

                var filePath = Path.Combine("wwwroot", "uploads", dsToDelete.FileName);
                if (File.Exists(filePath))
                {
                    File.Delete(filePath);
                }
            }
        }
        catch { }

        var result = await DatasetRepository.GetAllWithDetailsAsync();
        allDatasets = result.ToList();

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            var paperDatasetIds = await context.DatasetPapers
                .Select(p => p.DatasetId)
                .Distinct()
                .ToListAsync();
            datasetIdsWithPapers = new HashSet<int>(paperDatasetIds);

            var analyses = await context.DatasetAnalyses.ToListAsync();
            foreach (var analysis in analyses)
            {
                if (!string.IsNullOrEmpty(analysis.PerformanceJson))
                {
                    try
                    {
                        var performances = JsonSerializer.Deserialize<List<ModelPerformance>>(analysis.PerformanceJson);
                        if (performances != null && performances.Any())
                        {
                            var bestScore = performances.Max(p => p.score);
                            datasetBestScores[analysis.DatasetId] = bestScore;
                        }
                    }
                    catch { }
                }
            }
        }
        catch { }
    }

    private void SetFilter(string filter) => activeFilter = filter;
    private void ResetFilters()
    {
        activeFilter = "all";
        searchTerm = "";
    }

    private IEnumerable<Dataset> GetDisplayList()
    {
        var list = allDatasets ?? new List<Dataset>();
        if (!string.IsNullOrWhiteSpace(searchTerm))
            list = list.Where(d => d.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

        // Analiz yüzdelerine göre (en yüksek başarı oranına göre) yüksekten düşüğe sırala
        list = list.OrderByDescending(d => datasetBestScores.ContainsKey(d.Id) ? datasetBestScores[d.Id] : -1).ToList();

        list = activeFilter switch
        {
            "csv" => list.Where(d => !string.IsNullOrEmpty(d.FileName) && d.FileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase)).ToList(),
            "xlsx" => list.Where(d => !string.IsNullOrEmpty(d.FileName) && (d.FileName.EndsWith(".xlsx") || d.FileName.EndsWith(".xls"))).ToList(),
            "Classification" => list.Where(d => d.SubjectArea.Contains("Class", StringComparison.OrdinalIgnoreCase)).ToList(),
            "Regression" => list.Where(d => d.SubjectArea.Contains("Reg", StringComparison.OrdinalIgnoreCase)).ToList(),
            "newest" => list.OrderByDescending(d => d.UploadDate).ToList(),
            "most-viewed" => list.OrderByDescending(d => DatasetViewTracker.GetViews(d.Id)).ToList(),
            "highest-score" => list.OrderByDescending(d => datasetBestScores.ContainsKey(d.Id) ? datasetBestScores[d.Id] : -1).ToList(),
            "status-analyzed" => list.Where(d => datasetBestScores.ContainsKey(d.Id) && !d.SubjectArea.Contains("Error", StringComparison.OrdinalIgnoreCase) && !d.SubjectArea.Equals("Analysis Error", StringComparison.OrdinalIgnoreCase)).ToList(),
            "status-pending" => list.Where(d => d.SubjectArea.Equals("Awaiting Analysis", StringComparison.OrdinalIgnoreCase) || d.SubjectArea.Equals("Software/Technology", StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(d.SubjectArea)).ToList(),
            "status-error" => list.Where(d => d.SubjectArea.Contains("Error", StringComparison.OrdinalIgnoreCase) || d.SubjectArea.Equals("Analysis Error", StringComparison.OrdinalIgnoreCase)).ToList(),

            "scale-small" => list.Where(d => d.InstancesCount < 1000).ToList(),
            "scale-medium" => list.Where(d => d.InstancesCount >= 1000 && d.InstancesCount <= 10000).ToList(),
            "scale-large" => list.Where(d => d.InstancesCount > 10000).ToList(),
            "features-low" => list.Where(d => d.FeaturesCount.GetValueOrDefault() < 10).ToList(),
            "features-mid" => list.Where(d => d.FeaturesCount.GetValueOrDefault() >= 10 && d.FeaturesCount.GetValueOrDefault() <= 50).ToList(),
            "features-high" => list.Where(d => d.FeaturesCount.GetValueOrDefault() > 50).ToList(),
            "papers-has" => list.Where(d => datasetIdsWithPapers.Contains(d.Id)).ToList(),
            "papers-none" => list.Where(d => !datasetIdsWithPapers.Contains(d.Id)).ToList(),
            "size-small" => list.Where(d => d.FileSize < 102400).ToList(), // 100 KB
            "size-medium" => list.Where(d => d.FileSize >= 102400 && d.FileSize <= 5242880).ToList(), // 100 KB - 5 MB
            "size-large" => list.Where(d => d.FileSize > 5242880).ToList(), // > 5 MB
            _ => list
        };
        return list;
    }


    private string FormatSubjectArea(string? subjectArea)
    {
        if (string.IsNullOrEmpty(subjectArea)) return "Awaiting Analysis";
        if (subjectArea.Equals("Classification", StringComparison.OrdinalIgnoreCase)) return "Classification";
        if (subjectArea.Equals("Regression", StringComparison.OrdinalIgnoreCase)) return "Regression";
        if (subjectArea.Equals("Yazılım/Teknoloji", StringComparison.OrdinalIgnoreCase)) return "Awaiting Analysis";
        if (subjectArea.Equals("Software/Technology", StringComparison.OrdinalIgnoreCase)) return "Awaiting Analysis";
        if (subjectArea.Equals("Error", StringComparison.OrdinalIgnoreCase) || subjectArea.Contains("Error", StringComparison.OrdinalIgnoreCase)) return "Analysis Error";
        return subjectArea;
    }

    public class ModelPerformance {
        public string model_name { get; set; } = "";
        public double score { get; set; }
    }
}