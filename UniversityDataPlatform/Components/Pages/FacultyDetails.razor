@page "/faculty/{Id:int}"
@using UniversityDataPlatform.Models
@using UniversityDataPlatform.Repositories.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject IFacultyRepository FacultyRepository
@inject IDatasetRepository DatasetRepository
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="container-fluid mt-4 px-4">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border" style="color: #4f46e5;" role="status"></div>
        </div>
    }
    else if (faculty == null)
    {
        <div class="alert alert-danger py-5 text-center shadow-sm border-0 rounded-4 animate-slide-up">
            <i class="bi bi-exclamation-triangle fs-1 d-block mb-3 text-danger"></i>
            <h4 class="fw-bold text-dark">Academic Unit Not Found</h4>
            <p class="text-muted">The academic unit (faculty) you are looking for is not registered in the system.</p>
            <a href="/dashboard" class="btn text-white px-4 py-2 mt-2 border-0 shadow-sm" style="background-color: #4f46e5; border-radius: 10px;">
                <i class="bi bi-arrow-left"></i> Back to Home
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @* SOL TARAF: VERİ SETİ LİSTESİ *@
            <div class="col-md-9">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-4 small bg-light p-2 rounded">
                        <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none">Pool</a></li>
                        <li class="breadcrumb-item"><a href="/faculties" class="text-decoration-none">Faculties</a></li>
                        <li class="breadcrumb-item active">@faculty.Name</li>
                    </ol>
                </nav>

                <div class="d-flex align-items-center mb-4">
                    <div class="text-white rounded p-3 me-3" style="background-color: #4f46e5;">
                        <i class="bi bi-building fs-3"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold text-dark mb-0">@faculty.Name</h2>
                        <p class="text-muted mb-0">Listing published datasets belonging to this faculty.</p>
                    </div>
                </div>
                
                @if (datasets == null || !datasets.Any(x => x.FacultyId == Id))
                {
                    <div class="alert alert-light border shadow-sm py-4 text-center">
                        <i class="bi bi-folder-x fs-2 text-muted mb-3 d-block"></i>
                        <h5 class="text-secondary">No Datasets Yet</h5>
                        <p class="small text-muted">No datasets have been shared for this faculty yet.</p>
                        @if (!string.IsNullOrEmpty(uploadErrorMessage))
                        {
                            <div class="text-danger small fw-bold mb-2">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> @uploadErrorMessage
                            </div>
                        }
                        <button class="btn btn-primary btn-sm mt-2 border-0" style="background-color: #4f46e5;" @onclick="HandleUploadClick">Be the First to Upload Data</button>
                    </div>
                }
                else
                {
                    var filteredList = GetFilteredDatasets();
                    if (!filteredList.Any())
                    {
                        <div class="alert alert-light border shadow-sm py-5 text-center">
                            <i class="bi bi-filter-circle fs-1 text-muted mb-3 d-block"></i>
                            <h5 class="text-secondary fw-bold">No Datasets Match the Filter</h5>
                            <p class="small text-muted">No dataset matching the selected quick filter was found.</p>
                            <button class="btn btn-sm text-white px-3 py-2 border-0 mt-2" style="background-color: #4f46e5; border-radius: 8px;" @onclick='() => SetQuickFilter("all")'>
                                <i class="bi bi-arrow-counterclockwise"></i> Show All
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="dataset-list shadow-sm rounded border overflow-hidden">
                            @foreach (var ds in filteredList)
                            {
                                <a href="/dataset-details/@ds.Id" class="dataset-item list-group-item list-group-item-action p-4 border-bottom border-0">
                                    <div class="row align-items-center">
                                        <div class="col-auto">
                                            <div class="dataset-icon bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center">
                                                <i class="bi bi-database-fill fs-4"></i>
                                            </div>
                                        </div>
                                        
                                        <div class="col px-4">
                                            <h5 class="fw-bold text-dark mb-1">@ds.Title</h5>
                                            <p class="text-muted small mb-2 text-truncate" style="max-width: 500px;">
                                                @ds.Description
                                            </p>
                                            <div class="d-flex gap-3 text-muted x-small-text">
                                                <span class="badge bg-light text-dark border fw-normal">
                                                    <i class="bi bi-calendar3 me-1"></i> @ds.UploadDate.ToShortDateString()
                                                </span>
                                                <span><i class="bi bi-person me-1"></i> @ds.UploaderUser?.FullName</span>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="row text-center border-start">
                                                <div class="col">
                                                    <div class="fw-bold text-dark small">Analysis Type</div>
                                                    <div class="text-muted x-small-text">@FormatSubjectArea(ds.SubjectArea)</div>
                                                </div>
                                                <div class="col border-start border-end">
                                                    <div class="fw-bold text-dark small">Instances</div>
                                                    <div class="text-muted x-small-text">@ds.InstancesCount</div>
                                                </div>
                                                <div class="col">
                                                    <div class="fw-bold text-dark small">Features</div>
                                                    <div class="text-muted x-small-text">@(ds.FeaturesCount ?? 0)</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                }
            </div>

            @* SAĞ TARAF: BİLGİ PANELİ *@
            <div class="col-md-3">
                <div class="card border-0 shadow-sm sticky-top" style="top: 20px; border-top: 4px solid #4f46e5 !important;">
                    <div class="card-body py-4">
                        @if (!string.IsNullOrEmpty(uploadErrorMessage))
                        {
                            <div class="text-danger small fw-bold mb-2 text-center">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> @uploadErrorMessage
                            </div>
                        }
                        <div class="d-grid gap-2 mb-4">
                            <button class="btn fw-bold py-2 shadow-sm text-white border-0" style="background-color: #4f46e5;" @onclick="HandleUploadClick">
                                <i class="bi bi-plus-circle-fill me-1"></i> UPLOAD DATASET
                            </button>
                        </div>

                        <h6 class="fw-bold border-bottom pb-2 mb-3 small text-uppercase">Faculty Summary</h6>
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1 small">
                                <span>Total Datasets:</span>
                                <span class="fw-bold">@(datasets?.Count(x => x.FacultyId == Id) ?? 0)</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" style="width: 100%; background-color: #4f46e5;"></div>
                            </div>
                        </div>

                        <h6 class="fw-bold small text-uppercase mb-2">Quick Filters</h6>
                        <div class="d-flex flex-wrap gap-1 mb-4">
                            <span class="badge border fw-normal p-2 quick-filter-badge @(activeQuickFilter == "Classification" ? "active" : "bg-light text-dark")" @onclick='() => SetQuickFilter("Classification")'>Classification</span>
                            <span class="badge border fw-normal p-2 quick-filter-badge @(activeQuickFilter == "Regression" ? "active" : "bg-light text-dark")" @onclick='() => SetQuickFilter("Regression")'>Regression</span>
                            <span class="badge border fw-normal p-2 quick-filter-badge @(activeQuickFilter == "CSV" ? "active" : "bg-light text-dark")" @onclick='() => SetQuickFilter("CSV")'>CSV</span>
                            <span class="badge border fw-normal p-2 quick-filter-badge @(activeQuickFilter == "Excel" ? "active" : "bg-light text-dark")" @onclick='() => SetQuickFilter("Excel")'>Excel</span>
                        </div>
 
                        <div class="p-3 rounded bg-light border-start border-3" style="border-color: #4f46e5 !important;">
                            <p class="small text-muted mb-1"><i class="bi bi-shield-check"></i> Verified Source:</p>
                            <p class="small fw-bold mb-0">@faculty.Name Deanery</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bg-soft-primary { background-color: #eef2ff; }
    .text-primary { color: #4f46e5 !important; }
    .dataset-icon { width: 50px; height: 50px; border: 1px solid rgba(79, 70, 229, 0.2); }
    .dataset-item { transition: all 0.2s ease; background-color: white; border-left: 4px solid transparent; }
    .dataset-item:hover { background-color: #f8fbff; transform: translateX(5px); border-left: 4px solid #4f46e5; text-decoration: none !important; }
    .x-small-text { font-size: 0.8rem; }
    .breadcrumb-item a { color: #6c757d; }
    
    .quick-filter-badge {
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .quick-filter-badge:hover {
        background-color: #eef2ff !important;
        color: #4f46e5 !important;
        border-color: #4f46e5 !important;
    }
    .quick-filter-badge.active {
        background-color: #4f46e5 !important;
        color: white !important;
        border-color: #4f46e5 !important;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private Faculty? faculty;
    private IEnumerable<Dataset>? datasets;
    private int? loggedInUserFacultyId;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // Fakülte bilgilerini çek
            var all = await FacultyRepository.GetAllAsync();
            faculty = all.FirstOrDefault(f => f.Id == Id);
            
            // Bu fakülteye ait datasetleri detaylarıyla çek (Include Faculty/User için)
            datasets = await DatasetRepository.GetAllWithDetailsAsync();

            // Oturum açan kullanıcının Fakülte ID'sini al
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                var facultyIdClaim = user.FindFirst("FacultyId")?.Value;
                if (int.TryParse(facultyIdClaim, out var facId))
                {
                    loggedInUserFacultyId = facId;
                }
            }
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    private string activeQuickFilter = "all";

    private void SetQuickFilter(string filter)
    {
        if (activeQuickFilter == filter)
        {
            activeQuickFilter = "all";
        }
        else
        {
            activeQuickFilter = filter;
        }
    }

    private IEnumerable<Dataset> GetFilteredDatasets()
    {
        var list = datasets?.Where(x => x.FacultyId == Id) ?? Enumerable.Empty<Dataset>();
        return activeQuickFilter switch
        {
            "Classification" => list.Where(d => d.SubjectArea.Contains("Class", StringComparison.OrdinalIgnoreCase)),
            "Regression" => list.Where(d => d.SubjectArea.Contains("Reg", StringComparison.OrdinalIgnoreCase)),
            "CSV" => list.Where(d => !string.IsNullOrEmpty(d.FileName) && d.FileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase)),
            "Excel" => list.Where(d => !string.IsNullOrEmpty(d.FileName) && (d.FileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) || d.FileName.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))),
            _ => list
        };
    }

    private string? uploadErrorMessage;

    private void HandleUploadClick()
    {
        if (loggedInUserFacultyId == Id)
        {
            NavigationManager.NavigateTo("/upload-dataset");
        }
        else
        {
            uploadErrorMessage = "You do not have permission to upload datasets to this faculty.";
        }
    }

    private string FormatSubjectArea(string? subjectArea)
    {
        if (string.IsNullOrEmpty(subjectArea)) return "Awaiting Analysis";
        if (subjectArea.Equals("Classification", StringComparison.OrdinalIgnoreCase)) return "Classification";
        if (subjectArea.Equals("Regression", StringComparison.OrdinalIgnoreCase)) return "Regression";
        if (subjectArea.Equals("Yazılım/Teknoloji", StringComparison.OrdinalIgnoreCase)) return "Awaiting Analysis";
        if (subjectArea.Equals("Error", StringComparison.OrdinalIgnoreCase) || subjectArea.Contains("Error", StringComparison.OrdinalIgnoreCase)) return "Analysis Error";
        return subjectArea;
    }
}