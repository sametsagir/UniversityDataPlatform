@code {
    [Parameter] public int Id { get; set; }
    private Dataset? currentDataset;
    private List<string>? headers;
    private long fileSize = 0;
    private AnalysisResult? pythonResult;
    private bool isAnalyzing = false;
    private bool isAuthenticated = false;

    private List<DatasetPaper> datasetPapers = new();
    private bool showManualForm = false;
    private bool showAiSearch = false;
    private string searchAiQuery = "";
    private string aiSearchError = "";
    private string saveError = "";
    private bool isSearchingAi = false;
    private List<AcademicSearchPaper> aiSearchResults = new();
    private DatasetPaper newPaper = new() { Year = DateTime.Now.Year };

    private void ToggleManualForm()
    {
        showManualForm = !showManualForm;
        if (showManualForm) showAiSearch = false;
    }

    private void ToggleAiSearch()
    {
        showAiSearch = !showAiSearch;
        if (showAiSearch) showManualForm = false;
    }

    private async Task SaveManualPaper()
    {
        if (string.IsNullOrWhiteSpace(newPaper.Title)) return;
        if (string.IsNullOrWhiteSpace(newPaper.Url)) return;
        
        try
        {
            string cleanUrl = newPaper.Url.Trim();
            if (!Uri.TryCreate(cleanUrl, UriKind.Absolute, out var validatedUri) || 
                !(validatedUri.Scheme == Uri.UriSchemeHttp || validatedUri.Scheme == Uri.UriSchemeHttps))
            {
                saveError = "Please enter a valid URL (e.g. https://example.com).";
                StateHasChanged();
                return;
            }

            string domain = "Web Source";
            try
            {
                domain = validatedUri.Host;
                if (domain.StartsWith("www."))
                {
                    domain = domain.Substring(4);
                }
            }
            catch {}

            newPaper.DatasetId = Id;
            newPaper.Title = newPaper.Title.Trim();
            newPaper.Authors = "Not specified";
            newPaper.Venue = domain;
            newPaper.Year = DateTime.Now.Year;
            newPaper.Url = cleanUrl;

            await DatasetRepository.AddPaperAsync(newPaper);
            
            newPaper = new DatasetPaper { Year = DateTime.Now.Year };
            datasetPapers = await DatasetRepository.GetPapersByDatasetIdAsync(Id);
            showManualForm = false;
            saveError = "";
        }
        catch (Exception ex)
        {
            saveError = $"Failed to save paper: {ex.Message} (Details: {ex.InnerException?.Message ?? "None"})";
            Console.WriteLine($"Error saving manual paper: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task DeletePaper(int paperId)
    {
        try
        {
            await DatasetRepository.DeletePaperAsync(paperId);
            datasetPapers = await DatasetRepository.GetPapersByDatasetIdAsync(Id);
            saveError = "";
        }
        catch (Exception ex)
        {
            saveError = $"Failed to delete paper: {ex.Message} (Details: {ex.InnerException?.Message ?? "None"})";
            Console.WriteLine($"Error deleting paper: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task SearchAiPapers()
    {
        if (string.IsNullOrWhiteSpace(searchAiQuery)) return;
        
        isSearchingAi = true;
        aiSearchError = "";
        aiSearchResults.Clear();
        StateHasChanged();
        
        try
        {
            var searchResult = await AcademicSearchService.SearchPapersAsync(searchAiQuery);
            if (!searchResult.IsSuccess)
            {
                aiSearchError = searchResult.ErrorMessage;
            }
            else
            {
                aiSearchResults = searchResult.Papers;
            }
        }
        catch (Exception ex)
        {
            aiSearchError = "A technical error occurred during the academic search.";
            Console.WriteLine($"Search papers error: {ex.Message}");
        }
        finally
        {
            isSearchingAi = false;
            StateHasChanged();
        }
    }

    private async Task SaveAiPaper(AcademicSearchPaper apiPaper)
    {
        try
        {
            var authorNames = apiPaper.authors != null && apiPaper.authors.Any()
                ? string.Join(", ", apiPaper.authors.Select(a => a.name))
                : "Not specified";

            var paper = new DatasetPaper
            {
                DatasetId = Id,
                Title = (apiPaper.title ?? "Untitled Paper").Trim(),
                Authors = authorNames,
                Year = apiPaper.year ?? DateTime.Now.Year,
                Venue = string.IsNullOrWhiteSpace(apiPaper.venue) ? "Academic Publication" : apiPaper.venue.Trim(),
                Url = apiPaper.url?.Trim() ?? "https://www.semanticscholar.org"
            };

            await DatasetRepository.AddPaperAsync(paper);
            datasetPapers = await DatasetRepository.GetPapersByDatasetIdAsync(Id);
            saveError = "";
        }
        catch (Exception ex)
        {
            saveError = $"Failed to save paper: {ex.Message} (Details: {ex.InnerException?.Message ?? "None"})";
            Console.WriteLine($"Error saving AI paper: {ex.Message}");
        }
        StateHasChanged();
    }

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        }
        catch { }

        try
        {
            currentDataset = await DatasetRepository.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dataset: {ex.Message}");
        }

        if (currentDataset != null)
        {
            DatasetViewTracker.IncrementView(Id);
            try
            {
                await LoadHeaders();
                await LoadFileInfo();

                if (headers != null && headers.Any() && string.IsNullOrEmpty(selectedTargetColumn))
                {
                    selectedTargetColumn = headers.Last();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading dataset headers/files: {ex.Message}");
            }

            try
            {
                // Veritabanında kayıtlı analiz varsa yükle
                var existingAnalysis = await DatasetRepository.GetAnalysisByDatasetIdAsync(Id);
                if (existingAnalysis != null)
                {
                    MapExistingAnalysis(existingAnalysis);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading existing analysis: {ex.Message}");
            }

            try
            {
                // Akademik atıfları yükle
                datasetPapers = await DatasetRepository.GetPapersByDatasetIdAsync(Id);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading academic papers: {ex.Message}");
                datasetPapers = new List<DatasetPaper>();
            }
        }
        isLoading = false;
    }

    private void MapExistingAnalysis(DatasetAnalysis existing)
    {
        try 
        {
            pythonResult = new AnalysisResult
            {
                instances = existing.Instances,
                features = existing.Features,
                task_type = existing.TaskType,
                performance = !string.IsNullOrEmpty(existing.PerformanceJson) 
                    ? JsonSerializer.Deserialize<List<ModelPerformance>>(existing.PerformanceJson)! : new(),
                variables = !string.IsNullOrEmpty(existing.VariablesJson)
                    ? JsonSerializer.Deserialize<List<VariableInfo>>(existing.VariablesJson)! : new(),
                charts = !string.IsNullOrEmpty(existing.ChartsJson)
                    ? JsonSerializer.Deserialize<Dictionary<string, string>>(existing.ChartsJson)! : new()
            };

            if (pythonResult.variables.Any())
            {
                headers = pythonResult.variables.Select(v => v.name).ToList();
                excludedColumns.Clear();
                foreach (var v in pythonResult.variables)
                {
                    if (v.role == "Target")
                    {
                        selectedTargetColumn = v.name;
                    }
                    else if (v.role == "Excluded")
                    {
                        excludedColumns.Add(v.name);
                    }
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Deserialization Error: {ex.Message}"); }
    }

    private async Task StartAnalysis()
    {
        isAnalyzing = true;
        StateHasChanged();

        try
        {
            var filePath = Path.Combine(HostEnvironment.WebRootPath, "uploads", currentDataset!.FileName);
            var scriptPath = Path.Combine(HostEnvironment.WebRootPath, "scripts", "analyzer.py");

            var start = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "python",
                Arguments = $"\"{scriptPath}\" \"{filePath}\" \"{selectedTargetColumn}\" \"{string.Join(",", excludedColumns)}\"",
                UseShellExecute = false,
                RedirectStandardOutput = true,
                CreateNoWindow = true
            };

            using var process = System.Diagnostics.Process.Start(start);
            if (process != null)
            {
                using var reader = process.StandardOutput;
                string jsonOutput = await reader.ReadToEndAsync();
                pythonResult = JsonSerializer.Deserialize<AnalysisResult>(jsonOutput);

                if (pythonResult != null)
                {
                    var newAnalysis = new DatasetAnalysis
                    {
                        DatasetId = Id,
                        TaskType = pythonResult.task_type,
                        Instances = pythonResult.instances,
                        Features = pythonResult.features,
                        PerformanceJson = JsonSerializer.Serialize(pythonResult.performance),
                        VariablesJson = JsonSerializer.Serialize(pythonResult.variables),
                        ChartsJson = JsonSerializer.Serialize(pythonResult.charts),
                        AnalysisDate = DateTime.Now
                    };
                    await DatasetRepository.SaveAnalysisAsync(newAnalysis);
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Analysis Error: {ex.Message}"); }
        finally
        {
            isAnalyzing = false;
            StateHasChanged();
        }
    }

    private string FormatFileSize(long bytes)
    {
        string[] suffixes = { "Bytes", "KB", "MB", "GB" };
        int counter = 0;
        decimal number = (decimal)bytes;
        while (Math.Round(number / 1024) >= 1 && counter < suffixes.Length - 1)
        {
            number /= 1024;
            counter++;
        }
        return string.Format("{0:n1} {1}", number, suffixes[counter]);
    }

    private string FormatSubjectArea(string? subjectArea)
    {
        if (string.IsNullOrEmpty(subjectArea)) return "Awaiting Analysis";
        if (subjectArea.Equals("Classification", StringComparison.OrdinalIgnoreCase)) return "Classification";
        if (subjectArea.Equals("Regression", StringComparison.OrdinalIgnoreCase)) return "Regression";
        if (subjectArea.Equals("Yazılım/Teknoloji", StringComparison.OrdinalIgnoreCase)) return "Awaiting Analysis";
        if (subjectArea.Equals("Software/Technology", StringComparison.OrdinalIgnoreCase)) return "Awaiting Analysis";
        if (subjectArea.Equals("Error", StringComparison.OrdinalIgnoreCase) || subjectArea.Contains("Error", StringComparison.OrdinalIgnoreCase)) return "Analysis Error";
        return subjectArea;
    }

    private async Task DownloadDataset()
    {
        if (currentDataset != null)
        {
            var fileUrl = $"uploads/{currentDataset.FileName}";
            await JSRuntime.InvokeVoidAsync("downloadFileFromUrl", currentDataset.FileName, fileUrl);
        }
    }

    private async Task LoadHeaders()
    {
        try {
            var path = Path.Combine(HostEnvironment.WebRootPath, "uploads", currentDataset!.FileName);
            if (File.Exists(path)) {
                if (path.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) || path.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
                {
                    var start = new System.Diagnostics.ProcessStartInfo
                    {
                        FileName = "python",
                        Arguments = $"-c \"import pandas as pd; df = pd.read_excel(r'{path}', nrows=1); print(','.join(df.columns))\"",
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        CreateNoWindow = true
                    };
                    using var process = System.Diagnostics.Process.Start(start);
                    if (process != null)
                    {
                        using var reader = process.StandardOutput;
                        string output = await reader.ReadToEndAsync();
                        if (!string.IsNullOrWhiteSpace(output))
                        {
                            headers = output.Trim().Split(',').Select(h => h.Trim()).ToList();
                        }
                    }
                }
                else
                {
                    var lines = await File.ReadLinesAsync(path).Take(1).ToListAsync();
                    if (lines.Any()) {
                        headers = lines.First().Split(',').Select(h => h.Trim().Replace("\"", "")).ToList();
                    }
                }
            }
        } catch { }
    }

    private async Task LoadFileInfo()
    {
        try {
            var path = Path.Combine(HostEnvironment.WebRootPath, "uploads", currentDataset!.FileName);
            if (File.Exists(path)) fileSize = new FileInfo(path).Length;
        } catch { }
    }

    // --- EXCLUDE / TARGET STATE ---
    private List<string> excludedColumns = new();
    private string _selectedTargetColumn = "";
    private string selectedTargetColumn
    {
        get => _selectedTargetColumn;
        set
        {
            _selectedTargetColumn = value;
            if (excludedColumns.Contains(value))
            {
                excludedColumns.Remove(value);
            }
        }
    }

    private string GetColumnRole(string columnName)
    {
        if (columnName == selectedTargetColumn)
        {
            return "Target";
        }
        else if (excludedColumns.Contains(columnName))
        {
            return "Excluded";
        }
        else
        {
            return "Feature";
        }
    }

    private void OnExcludeCheckboxChanged(string columnName, ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked)
        {
            if (!excludedColumns.Contains(columnName))
            {
                excludedColumns.Add(columnName);
            }
        }
        else
        {
            if (excludedColumns.Contains(columnName))
            {
                excludedColumns.Remove(columnName);
            }
        }
    }

    // --- MODELLER ---
    public class AnalysisResult {
        public int instances { get; set; }
        public int features { get; set; }
        public string task_type { get; set; } = "";
        public string? error { get; set; }
        public List<ModelPerformance> performance { get; set; } = new();
        public List<VariableInfo> variables { get; set; } = new();
        public Dictionary<string, string> charts { get; set; } = new();
    }
    public class ModelPerformance {
        public string model_name { get; set; } = "";
        public double score { get; set; }
    }
    public class VariableInfo {
        public string name { get; set; } = "";
        public string role { get; set; } = "";
        public string type { get; set; } = "";
        public string missing { get; set; } = "";
    }
}