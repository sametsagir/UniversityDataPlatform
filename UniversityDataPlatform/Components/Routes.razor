@using Microsoft.AspNetCore.Components.Authorization
@using UniversityDataPlatform.Components.Layout

<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        @* PROFESYONEL DÜZEN:
           1. DefaultLayout'u 'EmptyLayout' yaptık (Sidebar sızıntısını engellemek için).
           2. AuthorizeRouteView yerine normal RouteView kullandık (Gecikmesiz Login için).
        *@
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(EmptyLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    
    <NotFound>
        @* Sayfa bulunamadığında sidebarlı düzeni gösterir *@
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="p-5 text-center text-white" style="background-color: #0f172a; min-height: 100vh;">
                <h1 class="display-1 fw-bold">404</h1>
                <p class="lead">Aradığınız akademik veri kümesi veya sayfa bulunamadı.</p>
                <a href="/dashboard" class="btn btn-primary mt-3">Ana Sayfaya Dön</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>